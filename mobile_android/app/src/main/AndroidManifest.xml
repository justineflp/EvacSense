<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.evacsense.auth">

    <!-- Permissions required for network requests -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Permissions required for real-world Wi-Fi Presence Scanning (Module 2) -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- Camera permissions for facial verification -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.NoActionBar"
        android:usesCleartextTraffic="true"> <!-- Permitting http transfers for local backend testing -->
        
        <!-- Login Entry Activity -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Secure Dashboard View Activity -->
        <activity
            android:name=".DashboardActivity"
            android:exported="false" />

        <!-- Self-Registration View Activity -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false" />

        <!-- Presence Recording Activity (Module 2) -->
        <activity
            android:name=".PresenceActivity"
            android:exported="false" />

        <!-- Evacuation Guidance & Rerouting Activity (Module 3) -->
        <activity
            android:name=".NavigationActivity"
            android:exported="false" />

        <!-- Assembly Area Check-In Activity (Module 4) -->
        <activity
            android:name=".CheckInActivity"
            android:exported="false" />

    </application>
</manifest>
