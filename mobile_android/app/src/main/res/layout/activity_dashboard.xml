<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#020617"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EvacSense Portal"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F172A"
        android:padding="20dp"
        android:layout_marginBottom="24dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/detailsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:lineSpacingExtra="8dp"
            android:text="Identity details..."/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E1E38"
        android:padding="20dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/actionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F59E0B"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:textStyle="bold"
            android:text="Role specific operations..."/>

    </LinearLayout>

    <Button
        android:id="@+id/presenceButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Scan/Log Classroom Presence"
        android:backgroundTint="#0EA5E9"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/checkInButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Check In at Assembly"
        android:backgroundTint="#10B981"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/navigationButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="🚨 Evacuation Guidance &amp; Rerouting"
        android:backgroundTint="#EF4444"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/logoutButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Logout Session"
        android:backgroundTint="#991B1B"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</LinearLayout>
