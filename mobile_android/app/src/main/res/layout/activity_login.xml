<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#020617">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Stylized Logo -->
        <View
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="16dp"
            android:background="#991B1B" />

        <TextView
            android:id="@+id/brandTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EvacSense"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/brandSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CIT-U Drill Suite"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:layout_marginBottom="32dp"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />

        <!-- Form Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0F172A"
            android:padding="20dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Institutional Email"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/emailInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="username@student.cit.edu"
                android:textColorHint="#64748B"
                android:textColor="#FFFFFF"
                android:inputType="textEmailAddress"
                android:background="#020617"
                android:padding="10dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="••••••••••••"
                android:textColorHint="#64748B"
                android:textColor="#FFFFFF"
                android:inputType="textPassword"
                android:background="#020617"
                android:padding="10dp"
                android:layout_marginBottom="20dp" />

            <!-- Error Banner -->
            <TextView
                android:id="@+id/errorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#EF4444"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                android:textStyle="bold" />

            <!-- Submit Button -->
            <Button
                android:id="@+id/loginButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Authenticate Session"
                android:backgroundTint="#F59E0B"
                android:textColor="#020617"
                android:textStyle="bold" />

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/loadingProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:indeterminateTint="#F59E0B" />

            <!-- Divider -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="or continue with"
                android:textColor="#64748B"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"
                android:textAllCaps="true" />

            <!-- Google Button -->
            <Button
                android:id="@+id/googleSsoButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Sign in with Google"
                android:backgroundTint="#FFFFFF"
                android:textColor="#1E293B"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Recovery Button -->
        <TextView
            android:id="@+id/recoveryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot Password or Account Recovery?"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:layout_marginTop="24dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>
