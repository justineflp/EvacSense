<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#020617">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join the EvacSense safety network"
            android:textColor="#94A3B8"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- Form Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0F172A"
            android:padding="20dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Profile Role"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/roleSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#020617"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/nameInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="e.g. Maria Santos"
                android:textColorHint="#64748B"
                android:textColor="#FFFFFF"
                android:inputType="textPersonName"
                android:background="#020617"
                android:padding="10dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Institutional Email"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/emailInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="username@student.cit.edu or @cit.edu"
                android:textColorHint="#64748B"
                android:textColor="#FFFFFF"
                android:inputType="textEmailAddress"
                android:background="#020617"
                android:padding="10dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/idLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Student or Employee ID"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/idInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="e.g. USR-006"
                android:textColorHint="#64748B"
                android:textColor="#FFFFFF"
                android:inputType="text"
                android:background="#020617"
                android:padding="10dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create Password"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/passwordInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="••••••••••••"
                    android:textColorHint="#64748B"
                    android:textColor="#FFFFFF"
                    android:inputType="textPassword"
                    android:background="#020617"
                    android:paddingStart="10dp"
                    android:paddingEnd="40dp" />

                <ImageView
                    android:id="@+id/passwordToggle"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|center_vertical"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_menu_view"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"/>
            </FrameLayout>

            <Button
                android:id="@+id/registerButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Submit Registration"
                android:backgroundTint="#F59E0B"
                android:textColor="#020617"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/regProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:indeterminateTint="#F59E0B" />

        </LinearLayout>

        <Button
            android:id="@+id/backToLoginButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="Return to Login"
            android:backgroundTint="#0F172A"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
